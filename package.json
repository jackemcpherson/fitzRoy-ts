{
  "name": "fitzroy",
  "version": "1.1.0",
  "description": "TypeScript library and CLI for AFL data — match results, player stats, fixtures, ladders, and more",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "fitzroy": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jackemcpherson/fitzRoy-ts.git"
  },
  "keywords": [
    "afl",
    "australian-football",
    "sports-data",
    "fitzroy",
    "aflw"
  ],
  "scripts": {
    "build": "bunup && bun run build.ts",
    "test": "vitest",
    "check": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "cheerio": "^1.0.0",
    "citty": "^0.2.1",
    "picocolors": "^1.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@types/node": "^25.5.0",
    "bunup": "^0.16.31",
    "esbuild": "^0.27.4",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  }
}
